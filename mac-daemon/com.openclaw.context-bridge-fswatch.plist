<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.context-bridge-fswatch</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__CONTEXT_BRIDGE_BIN_DIR__/context-bridge-fswatch.sh</string>
    </array>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>KeepAlive</key>
    <true/>
    
    <!-- Environment -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/context-bridge-fswatch.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/context-bridge-fswatch-error.log</string>
</dict>
</plist>
